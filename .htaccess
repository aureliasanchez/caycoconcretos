# .htaccess - CAYCO Concretos
# Redirecciones 301 para consolidar dominio canonico: https://cayco.mx
# Fecha: 18 Febrero 2026

RewriteEngine On

# 1. Redirigir www a non-www (301)
RewriteCond %{HTTP_HOST} ^www\.cayco\.mx$ [NC]
RewriteRule ^(.*)$ https://cayco.mx/$1 [R=301,L]

# 2. Redirigir HTTP a HTTPS (301)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://cayco.mx/$1 [R=301,L]

# 4. Redirecciones SEO: URLs semánticas (301)
RewriteRule ^service-1\.html$ /tipos-concreto.html [R=301,L]
RewriteRule ^service-2\.html$ /concretos-innovacion.html [R=301,L]
RewriteRule ^service-3\.html$ /bombeo-concreto.html [R=301,L]
RewriteRule ^service-4\.html$ /asesoria-capacitacion.html [R=301,L]

# 5. PSEO: Hubs de sucursal y categoría (7 hubs)
RewriteRule ^queretaro/?$ /pseo/output/hubs/queretaro.html [L]
RewriteRule ^tulancingo/?$ /pseo/output/hubs/tulancingo.html [L]
RewriteRule ^pachuca/?$ /pseo/output/hubs/pachuca.html [L]
RewriteRule ^huauchinango/?$ /pseo/output/hubs/huauchinango.html [L]
RewriteRule ^zumpango/?$ /pseo/output/hubs/zumpango.html [L]
RewriteRule ^concretos-innovacion-hub/?$ /pseo/output/hubs/concretos-innovacion-hub.html [L]
RewriteRule ^nearshoring-queretaro-hub/?$ /pseo/output/hubs/nearshoring-queretaro-hub.html [L]

# 6. PSEO: Página central + 72 landing pages (reglas explícitas)
RewriteRule ^mercado-concreto/?$ /pseo/output/mercado-concreto.html [L]
RewriteRule ^bomba-concreto-queretaro/?$ /pseo/output/bomba-concreto-queretaro.html [L]
